# 2Care Voice AI Agent - Environment Variables
# Copy to .env and fill in your values

APP_ENV=development
CORS_ALLOW_ORIGINS=["*"]

# Database: sqlite (no Docker) or postgres
DATABASE_URL=sqlite:///./voice_ai.db

# Memory: memory:// (no Docker) or redis
REDIS_URL=memory://

# OpenAI (required for STT, LLM, TTS)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_API_BASE=

# Model overrides
LLM_MODEL=gpt-4o-mini
STT_MODEL=whisper-1
TTS_MODEL=tts-1

# Latency target (ms)
LATENCY_TARGET_MS=450
